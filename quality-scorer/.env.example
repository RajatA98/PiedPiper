# PiedPiper frontend — Vite build env vars.
#
# Copy to .env.production after Phase 7 deploy and replace the placeholder
# with your actual Hugging Face Space URL.

# The HF Space URL where the FastAPI backend lives. Vite bakes this into the
# JS bundle at build time — it appears as a literal string in the shipped JS.
# Don't put anything secret here.
VITE_API_URL=https://CHANGEME-piedpiper.hf.space

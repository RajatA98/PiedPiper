# PiedPiper backend (HF Space) — runtime env vars.
#
# Set these as Space Secrets in the Hugging Face dashboard (Space → Settings →
# Secrets). The CORPUS_DIR can stay defaulted unless you mount a custom volume.

# --- CORS -------------------------------------------------------------------
# Local dev origin. Production wildcards via the regex baked into api.py.
CORS_ORIGIN=http://localhost:5173

# --- Corpus location --------------------------------------------------------
# Optional. Defaults to <repo>/quality-scorer/public/corpus.
# CORPUS_DIR=/data/corpus

# --- CLAP model pin ---------------------------------------------------------
# Optional. When set, manifest writes embed this revision SHA so re-runs
# are auditable. Match the SHA committed in manifest.json.
PIEDPIPER_CLAP_REVISION=a0b4534a14f58e20944452dff00a22a06ce629d1

# --- ACRCloud (Phase 5) -----------------------------------------------------
# Master gate. When false (or missing), both ACRCloud signals return
# `status="disabled"` and no network call is made.
ENABLE_ACRCLOUD=false

# Identification API region host — `identify-us-west-2.acrcloud.com`,
# `identify-eu-west-1.acrcloud.com`, etc.
ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=

# AI Music Detector endpoint + bearer token (console API; differs from the
# Identification API auth). Confirm the exact path from ACRCloud docs.
ACRCLOUD_AI_DETECTOR_URL=
ACRCLOUD_AI_DETECTOR_BEARER=

# Per-call timeout in seconds. 10 is generous; the live API typically
# returns in 1–3 s.
ACRCLOUD_TIMEOUT_S=10

# --- Sentry observability (Phase 7) -----------------------------------------
# Optional. When SENTRY_DSN is unset, sentry_sdk.init is skipped entirely
# (no network calls, no overhead).
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
